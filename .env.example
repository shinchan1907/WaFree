# Copy to .env before `docker compose up -d` (optional but recommended)

# Long random string — REQUIRED in production so logins survive restarts.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=

# How long login sessions last (e.g. 12h, 7d)
JWT_EXPIRES_IN=12h

# Host port to expose the dashboard on
WAFREE_PORT=4000
